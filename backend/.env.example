# Tavus AI Configuration
# Get these values from https://app.tavusapi.com
TAVUS_API_KEY=your_real_api_key_here_get_from_dashboard
TAVUS_API_URL=https://tavusapi.com/v2
TAVUS_PERSONA_ID=p_your_persona_id_here
TAVUS_REPLICA_ID=r_your_replica_id_here

# Supabase Configuration
# Get these from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_key_here

# Server Configuration
PORT=5000
NODE_ENV=development

# Optional: Database direct connection (if not using Supabase)
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Optional: JWT secret for authentication
JWT_SECRET=your_jwt_secret_here_change_in_production

# Optional: CORS settings
CORS_ORIGIN=http://localhost:3000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
